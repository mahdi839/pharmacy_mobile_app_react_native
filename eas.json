{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
       "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://medbangladesh.com/api"
      }
    },
    "preview": {
      "distribution": "internal",
       "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://medbangladesh.com/api"
      }
    },
    "production": {
      "autoIncrement": true,
       "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://medbangladesh.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
